# SITE_ADDRESS controla o modo:
#  - "ia.sconnecta.com.br"  -> Caddy emite HTTPS sozinho (deploy em VPS com portas 80/443)
#  - ":8080" (padrão)        -> HTTP simples (use atrás do Cloudflare Tunnel, sem abrir portas)
{$SITE_ADDRESS::8080} {
	encode gzip

	# API + WebSocket de logs vão para o backend
	@api path /api/*
	reverse_proxy @api backend:8001

	# SPA React (qualquer outra rota cai no index.html)
	root * /srv
	try_files {path} /index.html
	file_server
}
